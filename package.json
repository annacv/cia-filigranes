{
  "name": "cia-filigranes",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "./scripts/run-with-node.sh --no-deprecation node_modules/.bin/nuxt build",
    "dev": "./scripts/run-with-node.sh --no-deprecation node_modules/.bin/nuxt dev",
    "generate": "./scripts/run-with-node.sh node_modules/.bin/tsx scripts/prepare-robots.ts && ./scripts/run-with-node.sh --no-deprecation node_modules/.bin/nuxt generate",
    "generate:preview": "PREVIEW=true ./scripts/run-with-node.sh node_modules/.bin/tsx scripts/prepare-robots.ts && ./scripts/run-with-node.sh --no-deprecation node_modules/.bin/nuxt generate",
    "preview": "./scripts/run-with-node.sh --no-deprecation node_modules/.bin/nuxt preview",
    "postinstall": "./scripts/run-with-node.sh --no-deprecation node_modules/.bin/nuxt prepare",
    "lint": "eslint --ext .ts,.js,.vue",
    "lint:fix": "eslint --ext .ts,.js,.vue --fix",
    "optimize:images": "./scripts/run-with-node.sh node_modules/.bin/tsx scripts/optimize-images.ts",
    "deployTest": "npx firebase-tools deploy"
  },
  "dependencies": {
    "@nuxt/scripts": "^1.0.1",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@unhead/vue": "^2.1.13",
    "@vueuse/core": "^14.2.1",
    "firebase": "^12.12.1",
    "jszip": "^3.10.1",
    "nuxt": "^4.4.2",
    "nuxt-svgo": "^4.2.6",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^25.6.0",
    "@types/youtube": "^0.2.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "firebase-tools": "^15.15.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@koa/router": "^15.0.0",
    "svgo": "^4.0.1",
    "vue-i18n": "^11.3.2",
    "@types/youtube": "^0.2.0"
  }
}
